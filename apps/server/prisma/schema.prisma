// Mafya RPG — S3: Business, InventoryItem, EquipmentPrice eklendi

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String

  level Int @default(1)
  xp    Int @default(0)

  strength     Int @default(5)
  agility      Int @default(5)
  intelligence Int @default(5)
  charisma     Int @default(5)

  cityId String @default("new_haven")

  cleanMoney Int @default(500)
  dirtyMoney Int @default(0)

  jailUntil       DateTime?
  hospitalUntil   DateTime?
  travelUntil     DateTime?
  protectionUntil DateTime?

  jailbreakSkill Int @default(0)

  // Yeni oyuncu bonusu: ilk 3 gün +%50 AP regen (GDD §12)
  newbieBonusUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens    RefreshToken[]
  transactionsFrom Transaction[]  @relation("txFrom")
  transactionsTo   Transaction[]  @relation("txTo")
  businesses       Business[]
  inventory        InventoryItem[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([playerId])
}

enum Currency {
  CLEAN
  DIRTY
}

model Transaction {
  id        String   @id @default(cuid())
  fromId    String?
  from      Player?  @relation("txFrom", fields: [fromId], references: [id])
  toId      String?
  to        Player?  @relation("txTo", fields: [toId], references: [id])
  amount    Int
  currency  Currency
  type      String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([fromId])
  @@index([toId])
  @@index([type, createdAt])
}

// GDD §3 — işletme + aklama kuyruğu
model Business {
  id       String @id @default(cuid())
  ownerId  String
  owner    Player @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  typeId   String // businesses.json id'si
  level    Int    @default(1)
  cityId   String

  launderQueue  Int     @default(0) // kuyruktaki kirli para (₺)
  rushMode      Boolean @default(false)
  // Pasif gelir: son tahsilat zamanı (Redis değil DB; saatlik cron işler)
  lastPassiveAt DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([typeId])
}

// GDD §4 — ekipman envanteri
model InventoryItem {
  id         String  @id @default(cuid())
  playerId   String
  player     Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  itemId     String  // equipment.json id'si
  durability Int
  equipped   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([playerId])
}

// GDD §4.3 — saatlik cron'un güncellediği dinamik fiyat
model EquipmentPrice {
  itemId    String @id
  cityId    String
  demand24h Int    @default(0)
  updatedAt DateTime @default(now())

  @@unique([itemId, cityId])
}
